      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#555555'>Total Orders</run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Semibold' fontsize='22'><![CDATA[<[federated.1p0spqz0drkzyx11dr3jd0gyghd6].[sum:Calculation_2572118397146550289:qk]>]]></run>
            <run>Æ&#10;</run>
            <run fontname='Tableau Medium' fontsize='12'><![CDATA[<[federated.1p0spqz0drkzyx11dr3jd0gyghd6].[sum:Calculation_2572118397146570770:qk]> ]]></run>
            <run fontcolor='#555555' fontsize='12'>vs PY</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sales DataSource' name='federated.1p0spqz0drkzyx11dr3jd0gyghd6' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Year' datatype='integer' default-format='n0;-0' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2023'>
              <calculation class='tableau' formula='2023' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1p0spqz0drkzyx11dr3jd0gyghd6'>
            <column aggregation='Sum' caption='Current Year' datatype='integer' default-format='n0;-0' name='[Calculation_2562829721748488196]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
            </column>
            <column aggregation='Sum' caption='Previous Year' datatype='integer' default-format='n0;-0' name='[Calculation_2562829721748946949]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1] - 1' />
            </column>
            <column caption='CY Customers' datatype='string' name='[Calculation_2572118397064232964]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date])= [Parameters].[Parameter 1] THEN&#13;&#10;[Customer ID]&#13;&#10;END' />
            </column>
            <column caption='CY Orders' datatype='string' name='[Calculation_2572118397145407502]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN&#13;&#10;[Order ID]&#13;&#10;END' />
            </column>
            <column caption='PY Orders' datatype='string' name='[Calculation_2572118397145710607]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN&#13;&#10;[Order ID]&#13;&#10;END' />
            </column>
            <column caption='% Diff Order' datatype='real' default-format='*▲ 0.00%; ▼ -0.00%;' name='[Calculation_2572118397146341392]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(COUNTD([Calculation_2572118397145407502]) - COUNTD([Calculation_2572118397145710607]))/COUNTD([Calculation_2572118397145710607])' />
            </column>
            <column caption='{COUNTD([CY Orders])}' datatype='integer' name='[Calculation_2572118397146550289]' role='measure' type='quantitative' user:unnamed='KPI Orders'>
              <calculation class='tableau' formula='{COUNTD([Calculation_2572118397145407502])}' />
            </column>
            <column caption='{[% Diff Order]}' datatype='real' name='[Calculation_2572118397146570770]' role='measure' type='quantitative' user:unnamed='KPI Orders'>
              <calculation class='tableau' formula='{[Calculation_2572118397146341392]}' />
            </column>
            <column caption='Max/Min Orders' datatype='integer' name='[Calculation_2572118397150396436]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF COUNTD([Calculation_2572118397145407502]) = WINDOW_MAX(COUNTD([Calculation_2572118397145407502]))&#13;&#10;THEN&#13;&#10;COUNTD([Calculation_2572118397145407502])&#13;&#10;ELSEIF &#13;&#10;COUNTD([Calculation_2572118397145407502]) = WINDOW_MIN(COUNTD([Calculation_2572118397145407502]))&#13;&#10;THEN&#13;&#10;COUNTD([Calculation_2572118397145407502])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column aggregation='Sum' caption='No of Orders per customer' datatype='integer' name='[Calculation_2572118397292412956]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{ FIXED [Calculation_2572118397064232964]:COUNTD([Calculation_2572118397145407502])}' />
            </column>
